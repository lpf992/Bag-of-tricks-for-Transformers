{
  "version": 1,
  "trainer_path": "exp/snoo/train_gpt.py",
  "launcher": {
    "nproc_per_node": 8,
    "master_port_base": 29500
  },
  "defaults": {
    "data_path": "./data/datasets/fineweb10B_sp1024",
    "tokenizer_path": "./data/tokenizers/fineweb_1024_bpe.model",
    "vocab_size": 1024,
    "train_batch_tokens": 524288,
    "train_seq_len": 1024,
    "warmup_steps": 20,
    "warmdown_iters": 1200,
    "enable_wandb": 1,
    "wandb_mode": "offline",
    "wandb_project": "bag-of-tricks-for-transformers",
    "wandb_api_key": "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",
    "num_layers": 9,
    "model_dim": 512,
    "num_heads": 8,
    "num_kv_heads": 4,
    "mlp_mult": 2,
    "snoo_enabled": 1,
    "snoo_lr": 0.68,
    "snoo_momentum": 0.37,
    "snoo_k": 28
  },
  "experiments": [
    {
      "name": "snoo-on-muon-fixed_time_10min",
      "trainer_path": "exp/snoo/train_gpt.py",
      "overrides": { "snoo_scope": "muon" },
      "control": {
        "mode": "fixed_compute",
        "target_wallclock_seconds": 600,
        "iterations_cap": 1000000
      }
    },
    {
      "name": "snoo-on-muon-fixed_tokens_10b",
      "trainer_path": "exp/snoo/train_gpt.py",
      "overrides": { "snoo_scope": "muon" },
      "control": {
        "mode": "fixed_tokens",
        "target_train_tokens": 10000000000
      }
    },
    {
      "name": "snoo-on-adamw-fixed_time_10min",
      "trainer_path": "exp/snoo/train_gpt.py",
      "overrides": { "snoo_scope": "adamw" },
      "control": {
        "mode": "fixed_compute",
        "target_wallclock_seconds": 600,
        "iterations_cap": 1000000
      }
    },
    {
      "name": "snoo-on-adamw-fixed_tokens_10b",
      "trainer_path": "exp/snoo/train_gpt.py",
      "overrides": { "snoo_scope": "adamw" },
      "control": {
        "mode": "fixed_tokens",
        "target_train_tokens": 10000000000
      }
    }
  ]
}
